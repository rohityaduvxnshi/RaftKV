{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "RaftKV Cluster",
  "uid": "raftkv",
  "tags": ["raftkv"],
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "schemaVersion": 39,
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Leader (1 = leader) by node",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 20 } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "raftkv_is_leader", "legendFormat": "{{node}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Current term by node",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "raftkv_current_term", "legendFormat": "{{node}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "commitIndex / lastApplied by node",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "raftkv_commit_index", "legendFormat": "commit {{node}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "raftkv_last_applied", "legendFormat": "applied {{node}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Write throughput (req/s, 2xx)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(raftkv_http_requests_total{code=~\"2..\"}[1m]))", "legendFormat": "requests/s" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request latency p50 / p99",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(raftkv_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(raftkv_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Log size (bytes) by node",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "raftkv_log_bytes", "legendFormat": "{{node}}" }
      ]
    }
  ]
}
